# Server Configuration
PORT=3001

# Webhook (use smee.io or ngrok for local testing)
WEBHOOK_PROXY_URL=https://smee.io/your-channel

# GitHub App Credentials
APP_ID=your_app_id

# IMPORTANT: Paste your GitHub App private key here
# Replace newlines with \n
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Webhook Secret (set while creating GitHub App)
WEBHOOK_SECRET=your_webhook_secret

# OAuth App Credentials (if used)
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Internal Service URL (Credo backend)
HEKA_SERVICE_URL=http://localhost:3000